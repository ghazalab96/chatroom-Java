<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            styleClass="app-background"
            fx:controller="at.ac.hcw.chat.client.controller.ChatController">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
            <Label text="Chat Room" styleClass="title-small"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Logged in as " styleClass="subtitle"/>
            <Label fx:id="usernameLabel" styleClass="username-label"/>
        </HBox>
    </top>

    <!-- Main area: messages + user list -->
    <center>
        <HBox>
            <!-- Messages -->
            <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" styleClass="scroll-pane">
                <VBox fx:id="messagesBox" spacing="6" styleClass="messages-box"/>
            </ScrollPane>

            <!-- Online users sidebar -->
            <VBox minWidth="160" maxWidth="200" styleClass="sidebar">
                <Label text="Online" styleClass="sidebar-title"/>
                <ListView fx:id="userListView" VBox.vgrow="ALWAYS" styleClass="user-list"/>
            </VBox>
        </HBox>
    </center>

    <!-- Bottom input bar -->
    <bottom>
        <HBox spacing="10" styleClass="input-bar">
            <TextField fx:id="messageField"
                       promptText="Write a message... (@username:text for private)"
                       HBox.hgrow="ALWAYS"
                       onAction="#sendMessage"/>
            <Button text="Send" onAction="#sendMessage" styleClass="primary-button"/>
        </HBox>
    </bottom>

</BorderPane>
